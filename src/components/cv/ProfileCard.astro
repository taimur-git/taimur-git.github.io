---
interface Props {
  name: string;
  title: string;
  photo: string;
  contact: {
    email: string;
    phone?: string;
    linkedin?: string;
    github?: string;
    location: string;
  };
  skills: {
    languages: string[];
    tools: string[];
    concepts: string[];
  };
  certifications: Array<{
    name: string;
    issuer: string;
    year: number;
    badge?: string;
    link?: string;
  }>;
  languages_spoken: Array<{ lang: string; level: string }>;
}

const { name, title, photo, contact, skills, certifications, languages_spoken } = Astro.props;
---

<aside class="profile-card">
  <img src={photo} alt={name} class="profile-photo" />

  <div class="profile-info">
    <h1 class="profile-name">{name}</h1>
    <p class="profile-title mono">{title}</p>
  </div>

  <div class="contact-list">
    {contact.email && (
      <a href={`mailto:${contact.email}`} class="contact-item no-print-href">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
        <span>{contact.email}</span>
      </a>
    )}
    {contact.phone && (
      <a href={`tel:${contact.phone}`} class="contact-item no-print-href">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.15 12a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.06 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.09 8.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21 16z"/></svg>
        <span>{contact.phone}</span>
      </a>
    )}
    {contact.linkedin && (
      <a href={`https://${contact.linkedin}`} class="contact-item no-print-href" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
        <span>{contact.linkedin}</span>
      </a>
    )}
    {contact.github && (
      <a href={`https://${contact.github}`} class="contact-item no-print-href" target="_blank" rel="noopener">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
        <span>{contact.github}</span>
      </a>
    )}
    <span class="contact-item">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0z"/><circle cx="12" cy="10" r="3"/></svg>
      <span>{contact.location}</span>
    </span>
  </div>

  <div class="sidebar-section">
    <h3 class="sidebar-label">skills</h3>
    <div class="skill-group">
      <span class="skill-category mono">languages</span>
      <div class="skill-pills">
        {skills.languages.map(s => <span class="skill-pill">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <span class="skill-category mono">tools</span>
      <div class="skill-pills">
        {skills.tools.map(s => <span class="skill-pill">{s}</span>)}
      </div>
    </div>
    <div class="skill-group">
      <span class="skill-category mono">concepts</span>
      <div class="skill-pills">
        {skills.concepts.map(s => <span class="skill-pill">{s}</span>)}
      </div>
    </div>
  </div>

  <div class="sidebar-section">
    <h3 class="sidebar-label">certifications</h3>
    {certifications.map(cert => (
      <div class="cert-item">
        {cert.badge && <img src={cert.badge} alt={cert.name} class="cert-badge-img" />}
        <div>
          <span class="cert-name">{cert.name}</span>
          <span class="cert-meta mono">{cert.issuer} · {cert.year}</span>
        </div>
      </div>
    ))}
  </div>

  <div class="sidebar-section">
    <h3 class="sidebar-label">languages</h3>
    {languages_spoken.map(l => (
      <div class="lang-item">
        <span class="lang-name">{l.lang}</span>
        <span class="lang-level mono">{l.level}</span>
      </div>
    ))}
  </div>
</aside>

<style>
  .profile-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .profile-photo {
    width: 100%;
    max-width: 200px;
    border-radius: var(--radius-lg);
    border: 0.5px solid var(--color-border);
  }

  .profile-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .profile-name {
    font-size: var(--font-size-xl);
    font-weight: var(--font-weight-medium);
  }

  .profile-title {
    color: var(--color-text-muted);
    font-size: var(--font-size-xs);
  }

  .contact-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding-top: var(--space-2);
    border-top: 0.5px solid var(--color-border);
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    text-decoration: none;
    word-break: break-all;
  }

  a.contact-item:hover {
    color: var(--color-accent);
    opacity: 1;
  }

  .contact-item svg {
    flex-shrink: 0;
    color: var(--color-text-faint);
  }

  .sidebar-section {
    border-top: 0.5px solid var(--color-border);
    padding-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .sidebar-label {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: var(--font-weight-regular);
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .skill-category {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
  }

  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
  }

  .skill-pill {
    font-family: var(--font-mono);
    font-size: var(--font-size-xs);
    padding: 1px var(--space-2);
    border-radius: var(--radius-full);
    background: var(--color-surface);
    border: 0.5px solid var(--color-border-strong);
    color: var(--color-text-muted);
  }

  .cert-item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
  }

  .cert-badge-img {
    height: 32px;
    width: auto;
    flex-shrink: 0;
  }

  .cert-name {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text);
  }

  .cert-meta {
    display: block;
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
  }

  .lang-item {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }

  .lang-name {
    font-size: var(--font-size-sm);
    color: var(--color-text);
  }

  .lang-level {
    font-size: var(--font-size-xs);
    color: var(--color-text-faint);
  }
</style>
