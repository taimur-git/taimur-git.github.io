---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/blog/PostCard.astro';
import TagPill from '../../components/blog/TagPill.astro';
import { getCollection } from 'astro:content';
import '../../styles/blog.css';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const allTags = [...new Set(posts.flatMap(p => p.data.tags))].sort();
---

<BaseLayout title="Writing">
  <div class="site-container" style="padding-top: var(--space-12);">
    <h1 style="font-size: var(--font-size-3xl); font-weight: var(--font-weight-medium); line-height: var(--line-height-tight);">writing</h1>
    {allTags.length > 0 && (
      <div class="tag-filter">
        {allTags.map(tag => <TagPill tag={tag} />)}
      </div>
    )}
    <div class="post-list">
      {posts.map(post => <PostCard post={post} />)}
    </div>
  </div>
</BaseLayout>
