---
import BaseLayout from '../layouts/BaseLayout.astro';
import ExperienceTimeline from '../components/timeline/ExperienceTimeline.astro';
---

<BaseLayout title="Taimur Rahman">
  <section class="hero site-container">
    <div class="hero-inner">
      <h1 class="hero-name">Taimur Rahman</h1>
      <p class="hero-tagline">process improvement · software engineer · quality coordinator</p>
      <p class="hero-bio">
        <span id="typewriter"></span><span class="tw-cursor" aria-hidden="true"></span>
      </p>
      <div class="hero-links">
        <a href="/cv" class="hero-link">view cv →</a>
<a href="/research" class="hero-link secondary">research</a>
      </div>
    </div>
  </section>

  <div class="timeline-label site-container">
    <span class="mono">experience &amp; timeline</span>
  </div>

  <ExperienceTimeline />
</BaseLayout>

<style>
  .hero {
    padding: var(--space-16) var(--space-6) var(--space-12);
  }

  .hero-inner {
    max-width: 72ch;
  }

  .hero-name {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-medium);
    line-height: var(--line-height-tight);
    margin-bottom: var(--space-3);
  }

  .hero-tagline {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-text-muted);
    margin-bottom: var(--space-4);
  }

  .hero-bio {
    font-size: var(--font-size-base);
    color: var(--color-text-muted);
    line-height: var(--line-height-body);
    margin-bottom: var(--space-6);
  }

  .hero-links {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .hero-link {
    font-family: var(--font-mono);
    font-size: var(--font-size-sm);
    color: var(--color-accent);
    padding: var(--space-2) var(--space-4);
    border: 0.5px solid var(--color-accent);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .hero-link:hover {
    background: var(--color-accent);
    color: white;
    opacity: 1;
  }

  .hero-link.secondary {
    color: var(--color-text-muted);
    border-color: var(--color-border-strong);
  }

  .hero-link.secondary:hover {
    background: transparent;
    color: var(--color-text);
    border-color: var(--color-text);
  }

  .timeline-label {
    color: var(--color-text-faint);
    font-size: var(--font-size-xs);
    padding-bottom: 0;
  }

  .tw-cursor {
    display: inline-block;
    width: 2px;
    height: 0.85em;
    background: var(--color-text-muted);
    margin-left: 2px;
    vertical-align: middle;
    animation: tw-blink 1s step-end infinite;
  }

  .tw-cursor.done {
    animation: none;
    opacity: 0;
  }

  @keyframes tw-blink {
    50% { opacity: 0; }
  }
</style>

<script>
  const el = document.getElementById('typewriter')!;
  const cursor = document.querySelector<HTMLElement>('.tw-cursor')!;

  const PHRASE = 'Welcome To My WebSight';
  const DELETE_COUNT = 5; // removes "Sight"
  const CORRECTION = 'site';
  const TYPE_MS = 55;
  const DELETE_MS = 70;
  const PAUSE_MS = 650;

  const sleep = (ms: number) => new Promise(r => setTimeout(r, ms));

  async function run() {
    for (const ch of PHRASE) {
      el.textContent += ch;
      await sleep(TYPE_MS);
    }
    await sleep(PAUSE_MS);
    for (let i = 0; i < DELETE_COUNT; i++) {
      el.textContent = el.textContent!.slice(0, -1);
      await sleep(DELETE_MS);
    }
    for (const ch of CORRECTION) {
      el.textContent += ch;
      await sleep(TYPE_MS);
    }
    await sleep(400);
    cursor.classList.add('done');
  }

  run();
</script>
